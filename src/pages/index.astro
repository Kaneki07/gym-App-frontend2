---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="GYM APP | Ecosistema de Alto Rendimiento">
  <div id="splash-screen" class="fixed inset-0 z-[200] bg-black flex items-center justify-center overflow-hidden">
    <div class="relative flex flex-col items-center">
      <h1 class="text-6xl md:text-8xl font-black uppercase tracking-tighter italic text-white splash-text">
        GYM <span class="text-red-600 drop-shadow-[0_0_20px_rgba(220,38,38,0.8)]">APP</span>
      </h1>
      <div class="h-1 bg-red-600 mt-4 splash-line shadow-[0_0_15px_rgba(220,38,38,1)]"></div>
    </div>
  </div>

  <main id="main-content" class="opacity-0 max-w-6xl mx-auto px-4 py-8 md:py-16 transition-opacity duration-1000">
    
    <section class="py-12 md:py-20 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative">
        <div class="relative z-10 order-2 lg:order-1">
            <h1 class="text-5xl sm:text-6xl md:text-7xl font-black text-white mb-6 uppercase tracking-tighter italic leading-[0.9] text-left">
                MÁS QUE UNA APP, <br/> <span class="text-red-600 drop-shadow-[0_0_15px_rgba(220,38,38,0.8)]">TU ARMADURA DIGITAL</span>
            </h1>
            <p class="text-lg md:text-xl text-gray-400 mb-10 max-w-xl font-medium leading-relaxed text-left">
                La plataforma definitiva para atletas que no dejan su progreso al azar. Gestiona tu entrenamiento, nutrición y biometría con tecnología de élite.
            </p>
            <div class="flex flex-wrap gap-4 justify-start">
                <a href="/login" class="px-10 py-4 bg-red-700 text-white text-lg font-black rounded-xl shadow-[0_0_20px_rgba(185,28,28,0.4)] hover:bg-red-600 transition-all duration-300 transform hover:scale-105 active:scale-95 uppercase tracking-widest">
                    Únete a la Élite
                </a>
            </div>
        </div>

        <div class="relative z-10 order-1 lg:order-2 flex justify-center items-center">
            <div class="absolute inset-0 bg-red-600/20 blur-[80px] rounded-full"></div>
            <div class="relative w-full max-w-md aspect-square flex items-center justify-center">
                <img src="/GymAppLogoOfc1.png" alt="Gym App Logo" class="w-full h-auto object-contain logo-float drop-shadow-[0_0_30px_rgba(220,38,38,0.5)]" />
            </div>
        </div>
    </section>

    <section class="py-20">
        <div class="text-center mb-16 reveal-on-scroll">
            <h2 class="text-xs font-black text-red-600 uppercase tracking-[0.5em] mb-2">Manual de Operaciones</h2>
            <h3 class="text-4xl md:text-6xl font-black text-white uppercase italic">Todo lo que <span class="text-zinc-500">puedes hacer</span></h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="reveal-on-scroll group p-8 bg-gradient-to-br from-zinc-900 to-black rounded-3xl border border-zinc-800 hover:border-red-600 transition-all duration-500">
                <div class="text-4xl mb-6 group-hover:scale-110 transition-transform inline-block">🤖</div>
                <h4 class="text-xl font-black text-white uppercase italic mb-3">IA Fit Scan</h4>
                <p class="text-gray-500 text-sm leading-relaxed">Olvida contar calorías manualmente. Toma una foto a tu plato y nuestra IA analizará macros y calorías al instante.</p>
                <div class="mt-6 h-1 w-0 group-hover:w-full bg-red-600 transition-all duration-500"></div>
            </div>

            <div class="reveal-on-scroll group p-8 bg-gradient-to-br from-zinc-900 to-black rounded-3xl border border-zinc-800 hover:border-red-600 transition-all duration-500">
                <div class="text-4xl mb-6 group-hover:scale-110 transition-transform inline-block">📝</div>
                <h4 class="text-xl font-black text-white uppercase italic mb-3">Bitácora de Élite</h4>
                <p class="text-gray-500 text-sm leading-relaxed">Registra cada serie, repetición y carga. Tu historial de entrenamiento es tu hoja de ruta hacia el éxito.</p>
                <div class="mt-6 h-1 w-0 group-hover:w-full bg-red-600 transition-all duration-500"></div>
            </div>

            <div class="reveal-on-scroll group p-8 bg-gradient-to-br from-zinc-900 to-black rounded-3xl border border-zinc-800 hover:border-red-600 transition-all duration-500">
                <div class="text-4xl mb-6 group-hover:scale-110 transition-transform inline-block">📊</div>
                <h4 class="text-xl font-black text-white uppercase italic mb-3">Control Biométrico</h4>
                <p class="text-gray-500 text-sm leading-relaxed">Monitorea tu porcentaje de grasa y medidas corporales. Lo que no se mide, no se puede mejorar.</p>
                <div class="mt-6 h-1 w-0 group-hover:w-full bg-red-600 transition-all duration-500"></div>
            </div>
        </div>
    </section>

    <section class="mt-24 space-y-32">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center reveal-on-scroll">
            <div>
                <div class="flex items-center gap-2 mb-4">
                    <span class="px-3 py-1 bg-red-600 text-white text-[10px] font-black uppercase tracking-widest rounded">Modo Coach</span>
                </div>
                <h3 class="text-4xl md:text-5xl font-black text-white uppercase italic leading-tight mb-6">
                    Gestiona tu <span class="text-red-600">Imperio de Fitness</span>
                </h3>
                <p class="text-gray-400 text-lg mb-8 leading-relaxed">
                    Si eres entrenador, accede al **Centro de Comando**. Sube rutinas personalizadas, diseña planes nutricionales y gestiona a tus atletas desde una interfaz profesional.
                </p>
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-zinc-900/50 p-4 rounded-xl border border-zinc-800">
                        <p class="text-white font-bold uppercase italic text-xs">Programación</p>
                        <p class="text-gray-500 text-[10px]">Envío de rutinas técnicas.</p>
                    </div>
                    <div class="bg-zinc-900/50 p-4 rounded-xl border border-zinc-800">
                        <p class="text-white font-bold uppercase italic text-xs">Nutrición Pro</p>
                        <p class="text-gray-500 text-[10px]">Carga de dietas de precisión.</p>
                    </div>
                </div>
            </div>
            
            <div class="relative group">
                <div class="absolute inset-0 bg-red-600/20 blur-[60px] rounded-full group-hover:bg-red-600/30 transition-all"></div>
                <div class="relative bg-zinc-900 border border-white/10 p-8 rounded-[2rem] shadow-2xl">
                    <div class="space-y-4">
                        <div class="flex items-center justify-between p-4 bg-black/50 rounded-xl border-l-4 border-red-600">
                            <span class="text-white font-black uppercase italic text-sm">Rutinas Enviadas</span>
                            <span class="text-red-600 font-black">124</span>
                        </div>
                        <div class="flex items-center justify-between p-4 bg-black/50 rounded-xl border-l-4 border-zinc-700">
                            <span class="text-white font-black uppercase italic text-sm">Atletas Activos</span>
                            <span class="text-zinc-500 font-black">32</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mt-32 py-20 border-y border-zinc-900">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
            <div class="reveal-on-scroll">
                <p id="count-display" class="text-6xl font-black text-white mb-2 italic">...</p>
                <p class="text-red-600 font-black uppercase tracking-widest text-xs">Atletas Registrados</p>
            </div>
            <div class="reveal-on-scroll" style="transition-delay: 200ms;">
                <p class="text-6xl font-black text-white mb-2 italic">100%</p>
                <p class="text-red-600 font-black uppercase tracking-widest text-xs">Sin Anuncios / Puro Rendimiento</p>
            </div>
            <div class="reveal-on-scroll" style="transition-delay: 400ms;">
                <p class="text-6xl font-black text-white mb-2 italic">AI</p>
                <p class="text-red-600 font-black uppercase tracking-widest text-xs">Powered by Google Gemini</p>
            </div>
        </div>
    </section>

    <section class="py-32 text-center reveal-on-scroll">
        <h2 class="text-5xl md:text-7xl font-black text-white uppercase italic mb-8 leading-none">¿LISTO PARA EL <br><span class="text-red-600">SIGUIENTE NIVEL?</span></h2>
        <p class="text-gray-500 mb-12 max-w-2xl mx-auto font-medium">Únete hoy y accede a todas las herramientas de entrenamiento que utilizan los profesionales.</p>
        <a href="/register" class="inline-block px-12 py-5 bg-white text-black text-xl font-black rounded-2xl hover:bg-red-600 hover:text-white transition-all duration-500 uppercase tracking-tighter italic">
            Crear mi Cuenta Gratis
        </a>
    </section>

  </main>
</Layout>

<style>
  /* --- Splash Screen --- */
  .splash-text { animation: splashZoom 0.8s ease-out forwards; }
  .splash-line { width: 0; animation: lineGrow 0.6s 0.4s ease-out forwards; }
  @keyframes splashZoom { 0% { opacity: 0; transform: scale(0.9); } 100% { opacity: 1; transform: scale(1); } }
  @keyframes lineGrow { from { width: 0; } to { width: 100%; } }
  .fade-out-splash { opacity: 0; visibility: hidden; transition: opacity 0.6s ease-in-out, visibility 0.6s; }

  /* --- Logo Animation --- */
  .logo-float { animation: floatLogo 4s ease-in-out infinite; }
  @keyframes floatLogo {
    0%, 100% { transform: translateY(0px) scale(1); }
    50% { transform: translateY(-15px) scale(1.05); }
  }

  /* --- Animación al Bajar (Scroll Reveal) --- */
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1);
  }
  .reveal-on-scroll.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Tu lógica de conteo de usuarios y splash screen (Mantenida)
  async function fetchUserCount() {
    try {
        const response = await fetch('https://gym-app-backend-2-pv91.onrender.com/users/count');
        const data = await response.json();
        if (data.code === 200) {
            const countElement = document.getElementById('count-display');
            if (countElement) countElement.innerText = data.data.count;
        }
    } catch (error) {
        console.error("No se pudo obtener el contador de usuarios:", error);
    }
  }

  function initPage() {
    const token = localStorage.getItem('token');
    if (token) {
        window.location.href = '/dashboard';
        return; 
    }

    const splash = document.getElementById('splash-screen');
    const mainContent = document.getElementById('main-content');

    fetchUserCount();

    setTimeout(() => {
      if (splash) splash.classList.add('fade-out-splash');
      if (mainContent) {
        mainContent.classList.remove('opacity-0');
        mainContent.classList.add('opacity-100');
      }
      initScrollReveal();
    }, 2000);
  }

  function initScrollReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.reveal-on-scroll').forEach(target => observer.observe(target));
  }

  document.addEventListener('DOMContentLoaded', initPage);
</script>